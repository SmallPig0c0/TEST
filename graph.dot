graph G {
    layout=neato;
    overlap=false;
    splines=true;
    node [shape=circle, style=filled, fontname="Consolas"];
    edge [fontname="Consolas"];

    1 [label="1\nd=0", fillcolor="gold"];
    2 [label="2\nd=1", fillcolor="lightblue"];
    3 [label="3\nd=1", fillcolor="lightblue"];
    4 [label="4\nd=2", fillcolor="lightgreen"];
    5 [label="5\nd=3", fillcolor="lightpink"];

    1 -- 2 [color=red, penwidth=3];
    1 -- 3 [color=red, penwidth=3];
    2 -- 4 [color=red, penwidth=3];
    3 -- 4;
    4 -- 5 [color=red, penwidth=3];
}
